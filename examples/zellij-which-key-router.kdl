// Repo-local integration example for ~/.config/zellij/config.kdl.
// Build first: ./scripts/build-plugin
// Replace /absolute/path/to/zwk with this repository's absolute path.

keybinds clear-defaults=true {
    locked {
        bind "Ctrl Space" {
            MessagePlugin "file:/absolute/path/to/zwk/target/zellij/zellij-which-key-router.wasm" {
                name "zwk:show"
            }
        }
    }

    normal {
        bind "Ctrl Space" "Esc" { SwitchToMode "Locked"; }
        bind "p" { SwitchToMode "Pane"; }
    }

    pane {
        bind "Backspace" { SwitchToMode "Normal"; }
        bind "Ctrl Space" "Esc" { SwitchToMode "Locked"; }
    }
}

plugins {
    which-key-router location="file:/absolute/path/to/zwk/target/zellij/zellij-which-key-router.wasm"

    // Keep status/hint plugins independent of this floating overlay.
}

load_plugins {
    "file:/absolute/path/to/zwk/target/zellij/zellij-which-key-router.wasm"
}

// The overlay is passive: it reads Zellij's current keymap and renders hints.
// It does not intercept keys and does not run actions itself.
//
// Requested permissions:
// - ReadApplicationState
// - ChangeApplicationState
// - OpenTerminalsOrPlugins
//
// macOS fallback if the interactive prompt is unreliable: pre-approve the same
// plugin URL in Zellij's permissions.kdl using the normal permission-cache shape:
// "file:/absolute/path/to/zwk/target/zellij/zellij-which-key-router.wasm" {
//     ReadApplicationState
//     ChangeApplicationState
//     OpenTerminalsOrPlugins
// }
